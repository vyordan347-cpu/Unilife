@{
    ViewData["Title"] = "Panel Alumno";
}

<link rel="stylesheet" href="~/css/coordinador.css" asp-append-version="true" />

<div class="coordinador-page">

    <div class="coordinador-header">
        <h1>Panel Alumno</h1>
        <p>Bienvenido a UniLife. Consulta tus cursos, eventos y lugares.</p>
    </div>

    <div class="coordinador-grid">

        <a asp-controller="Cursos" asp-action="Index" class="coordinador-card">
            <div class="card-icon">📚</div>
            <h3>Ver cursos</h3>
            <p>Consulta los cursos, horarios y aulas.</p>
        </a>

        <a asp-controller="Eventos" asp-action="Index" class="coordinador-card">
            <div class="card-icon">📅</div>
            <h3>Ver eventos</h3>
            <p>Descubre talleres, charlas y eventos.</p>
        </a>

        <a asp-controller="Lugares" asp-action="Index" class="coordinador-card">
            <div class="card-icon">📍</div>
            <h3>Ver lugares</h3>
            <p>Restaurantes, cafeterías y bibliotecas cercanas.</p>
        </a>

    </div>

    <div class="logout-box">
        <form asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class="btn btn-outline-danger">Cerrar sesión</button>
        </form>
    </div>
</div>