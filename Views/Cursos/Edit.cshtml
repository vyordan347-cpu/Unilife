@model Unilife.Models.Curso

@{
    ViewData["Title"] = "Editar curso";
}

<h1>Editar curso</h1>

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="Nombre" class="form-label"></label>
        <input asp-for="Nombre" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Descripcion" class="form-label"></label>
        <textarea asp-for="Descripcion" class="form-control"></textarea>
    </div>

    <div class="mb-3">
        <label asp-for="Carrera" class="form-label"></label>
        <input asp-for="Carrera" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Semestre" class="form-label"></label>
        <input asp-for="Semestre" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Docente" class="form-label"></label>
        <input asp-for="Docente" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="HoraInicio" class="form-label"></label>
        <input asp-for="HoraInicio" class="form-control" type="time" />
    </div>

    <div class="mb-3">
        <label asp-for="HoraFin" class="form-label"></label>
        <input asp-for="HoraFin" class="form-control" type="time" />
    </div>

    <div class="mb-3">
        <label asp-for="Pabellon" class="form-label"></label>
        <input asp-for="Pabellon" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Aula" class="form-label"></label>
        <input asp-for="Aula" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Guardar cambios</button>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</form>