@model Unilife.Models.Curso

@{
    ViewData["Title"] = "Detalles del curso";
}

<h1>@Model.Nombre</h1>

<div class="card">
    <div class="card-body">
        <p><strong>Descripción:</strong> @Model.Descripcion</p>
        <p><strong>Carrera:</strong> @Model.Carrera</p>
        <p><strong>Semestre:</strong> @Model.Semestre</p>
        <p><strong>Docente:</strong> @Model.Docente</p>
        <p><strong>Horario:</strong> @Model.HoraInicio - @Model.HoraFin</p>
        <p><strong>Pabellón:</strong> @Model.Pabellon</p>
        <p><strong>Aula:</strong> @Model.Aula</p>
        <p><strong>Código de aula:</strong> @Model.CodigoAula</p>
    </div>
</div>

<br />

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
<a asp-action="Index" class="btn btn-secondary">Volver</a>