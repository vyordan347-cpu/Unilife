@model IEnumerable<Unilife.Models.Curso>

@{
    ViewData["Title"] = "Cursos";
}

<h1>Cursos</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Crear nuevo curso</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Carrera</th>
            <th>Semestre</th>
            <th>Docente</th>
            <th>Horario</th>
            <th>Aula</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var curso in Model)
{
        <tr>
            <td>@curso.Nombre</td>
            <td>@curso.Carrera</td>
            <td>@curso.Semestre</td>
            <td>@curso.Docente</td>
            <td>@curso.HoraInicio - @curso.HoraFin</td>
            <td>@curso.CodigoAula</td>
            <td>
                <a asp-action="Details" asp-route-id="@curso.Id">Detalles</a> |
                <a asp-action="Edit" asp-route-id="@curso.Id">Editar</a> |
                <a asp-action="Delete" asp-route-id="@curso.Id">Eliminar</a>
            </td>
        </tr>
}
    </tbody>
</table>