@model IEnumerable<Unilife.Models.Curso>

@{
    ViewData["Title"] = "Cursos";
}

<link rel="stylesheet" href="~/css/cursos.css" asp-append-version="true" />

<div class="d-flex justify-content-between align-items-center mb-2">
    <h1 class="page-title mb-0">Cursos</h1>

    @if (User.IsInRole("Coordinador"))
    {
        <a asp-action="Create" class="btn-crear">+ Crear curso</a>
    }
</div>
<p class="page-subtitle">Cursos y horarios del semestre</p>

<div class="cursos-grid">
    @foreach (var curso in Model)
    {
        <div class="curso-card">

            <div class="curso-card-top">
                <div class="curso-icon">📘</div>
                <div>
                    <div class="curso-title">@curso.Nombre</div>
                    <div class="curso-sub">@curso.Carrera · Semestre @curso.Semestre</div>
                </div>
            </div>

            <div class="curso-meta">
                <div class="curso-info">👨‍🏫 @curso.Docente</div>
                <div class="curso-info">🕒 @curso.HoraInicio.ToString(@"hh\:mm") - @curso.HoraFin.ToString(@"hh\:mm")</div>
                <div class="curso-info">📍 Aula @curso.CodigoAula</div>
            </div>

            <div class="curso-footer">
                <a asp-action="Details" asp-route-id="@curso.Id" class="btn-detalle">Ver detalles</a>

                @if (User.IsInRole("Coordinador"))
                {
                    <a asp-action="Edit" asp-route-id="@curso.Id" class="btn-edit">Editar</a>
                    <a asp-action="Delete" asp-route-id="@curso.Id" class="btn-delete">Eliminar</a>
                }
            </div>

        </div>
    }
</div>