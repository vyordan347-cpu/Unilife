@model IEnumerable<Unilife.Models.Curso>

@{
    ViewData["Title"] = "Cursos";
}

<link rel="stylesheet" href="~/css/cursos.css" asp-append-version="true" />

<div class="cursos-page">

    <div class="cursos-header">
        <h1>Cursos</h1>

        @if (User.IsInRole("Coordinador"))
        {
            <a asp-action="Create" class="btn-crear">+ Crear curso</a>
        }
    </div>

    <div class="cursos-grid">

        @foreach (var curso in Model)
        {
            <div class="curso-card">

                <div class="curso-title">@curso.Nombre</div>

                <div class="curso-info">Carrera: @curso.Carrera</div>
                <div class="curso-info">Semestre: @curso.Semestre</div>
                <div class="curso-info">Docente: @curso.Docente</div>
                <div class="curso-info">Horario: @curso.HoraInicio - @curso.HoraFin</div>
                <div class="curso-info">Aula: @curso.CodigoAula</div>

                <div class="curso-footer">

                    <a asp-action="Details" asp-route-id="@curso.Id" class="btn-detalle">
                        Detalles
                    </a>

                    @if (User.IsInRole("Coordinador"))
                    {
                        <a asp-action="Edit" asp-route-id="@curso.Id" class="btn-edit">
                            Editar
                        </a>

                        <a asp-action="Delete" asp-route-id="@curso.Id" class="btn-delete">
                            Eliminar
                        </a>
                    }

                </div>

            </div>
        }

    </div>

</div>