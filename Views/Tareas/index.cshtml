@model IEnumerable<Unilife.Models.Tarea>

@{
    ViewData["Title"] = "Tareas";
}

<link rel="stylesheet" href="~/css/inicio.css" asp-append-version="true" />

<div class="d-flex justify-content-between align-items-center mb-2">
    <h1 class="page-title mb-0">Mis tareas</h1>
    <a asp-action="Create" class="btn btn-danger px-4">+ Nueva tarea</a>
</div>
<p class="page-subtitle">Organiza tus entregas y pendientes</p>

@if (!Model.Any())
{
    <div class="dash-card" style="text-align:center; color:#6b7280;">
        Todavía no tienes tareas. Crea la primera con el botón "+ Nueva tarea".
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var t in Model)
        {
            string color = t.Prioridad == "Alta" ? "#dc2626"
                         : t.Prioridad == "Media" ? "#d97706" : "#059669";

            <div class="col-md-6">
                <div class="dash-card d-flex justify-content-between align-items-start"
                     style="@(t.Completada ? "opacity:.6;" : "")">
                    <div>
                        <div class="item-title" style="@(t.Completada ? "text-decoration:line-through;" : "")">
                            @t.Titulo
                        </div>
                        <div class="item-sub">@t.Curso · Entrega: @t.FechaEntrega.ToShortDateString()</div>
                        <span class="badge-pill" style="background:@color; color:#fff; margin-top:8px;">
                            @t.Prioridad
                        </span>
                    </div>

                    <div class="d-flex flex-column gap-2">
                        <form asp-action="Completar" asp-route-id="@t.Id" method="post">
                            <button type="submit" class="btn btn-sm btn-outline-success w-100">
                                @(t.Completada ? "Reabrir" : "✓ Completar")
                            </button>
                        </form>
                        <a asp-action="Edit" asp-route-id="@t.Id" class="btn btn-sm btn-outline-warning">Editar</a>
                        <a asp-action="Delete" asp-route-id="@t.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                    </div>
                </div>
            </div>
        }
    </div>
}