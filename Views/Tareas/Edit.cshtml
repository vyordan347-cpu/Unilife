@model Unilife.Models.Tarea

@{
    ViewData["Title"] = "Editar tarea";
}

<link rel="stylesheet" href="~/css/inicio.css" asp-append-version="true" />

<h1 class="page-title">Editar tarea</h1>
<p class="page-subtitle">Actualiza los datos de tu pendiente</p>

<div class="dash-card" style="max-width:520px;">
    <form asp-action="Edit" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="UsuarioId" />

        <div class="mb-3">
            <label asp-for="Titulo" class="form-label"></label>
            <input asp-for="Titulo" class="form-control" />
            <span asp-validation-for="Titulo" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Curso" class="form-label"></label>
            <input asp-for="Curso" class="form-control" />
            <span asp-validation-for="Curso" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="FechaEntrega" class="form-label"></label>
            <input asp-for="FechaEntrega" class="form-control" type="date" />
            <span asp-validation-for="FechaEntrega" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Prioridad" class="form-label"></label>
            <select asp-for="Prioridad" class="form-select">
                <option value="Alta">Alta</option>
                <option value="Media">Media</option>
                <option value="Baja">Baja</option>
            </select>
            <span asp-validation-for="Prioridad" class="text-danger"></span>
        </div>

        <div class="form-check mb-3">
            <input asp-for="Completada" class="form-check-input" />
            <label asp-for="Completada" class="form-check-label">Completada</label>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger px-4">Guardar cambios</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}