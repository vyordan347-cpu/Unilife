@model IEnumerable<Unilife.Models.Lugar>

@{
    ViewData["Title"] = "Lugares";
}

<div class="app-page">
    <aside class="sidebar-unilife">
        <div class="logo-unilife">🛡 UniLife</div>

        <a class="menu-link" asp-controller="Home" asp-action="Index">⌂ Inicio</a>
        <a class="menu-link" asp-controller="Cursos" asp-action="Index">☑ Cursos</a>
        <a class="menu-link active" asp-controller="Lugares" asp-action="Index">⌖ Lugares</a>
        <a class="menu-link" asp-controller="Eventos" asp-action="Index">▣ Eventos</a>
        <a class="menu-link" href="#">♙ Perfil</a>

        <div class="sidebar-card">
            <strong>¡Sigue así!</strong>
            <br />
            Explora nuevos lugares cerca de ti.
        </div>
    </aside>

    <main class="content-unilife">
        <h1 class="page-title">Lugares cercanos</h1>
        <p class="page-subtitle">Descubre restaurantes, cafeterías y bibliotecas cerca de ti</p>

        <form method="get" class="mb-4">
            <input type="text" name="buscar" value="@ViewBag.Buscar" class="form-control search-box" placeholder="🔍 Buscar lugares..." />
        </form>

        <div class="d-flex flex-wrap gap-2 mb-4">
            <a asp-action="Index" class="filter-btn active">Todos</a>
            <a asp-action="Index" asp-route-tipo="Restaurante" class="filter-btn">🍴 Restaurantes</a>
            <a asp-action="Index" asp-route-tipo="Cafetería" class="filter-btn">☕ Cafeterías</a>
            <a asp-action="Index" asp-route-tipo="Biblioteca" class="filter-btn">📖 Bibliotecas</a>
        </div>

        <div class="row g-4">
            @foreach (var item in Model)
            {
                string icono = "☕";

                if (item.Tipo == "Restaurante") icono = "🍴";
                else if (item.Tipo == "Biblioteca") icono = "📖";
                else if (item.Tipo == "Coworking") icono = "💻";

                <div class="col-md-4">
                    <div class="place-card">
                        <div class="d-flex justify-content-between">
                            <div class="place-icon">@icono</div>
                            <div class="rating-badge">⭐ @item.Calificacion</div>
                        </div>

                        <h5 class="place-title">@item.Nombre</h5>
                        <p class="place-description">@item.Descripcion</p>

                        <div class="place-footer">
                            <span>📍 @item.Distancia</span>
                            <span>💲 S/ @item.PrecioPromedio</span>
                        </div>

                        <div class="d-flex gap-2 mt-3">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm w-100">Ver</a>

                            @if (User.IsInRole("Coordinador"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm w-100">Editar</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm w-100">Eliminar</a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (User.IsInRole("Coordinador"))
        {
            <div class="mt-4">
                <a asp-action="Create" class="btn btn-danger px-4">+ Crear lugar</a>
            </div>
        }
    </main>
</div>