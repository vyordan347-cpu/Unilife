@model Unilife.Models.PerfilViewModel

@{
    ViewData["Title"] = "Mi perfil";
}

<link rel="stylesheet" href="~/css/inicio.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/perfil.css" asp-append-version="true" />

<div class="perfil-page">

    <!-- Cabecera -->
    <div class="perfil-header">
        <div class="perfil-avatar">👤</div>
        <div class="perfil-info">
            <h1>@Model.Nombre @Model.Apellido</h1>
            <div class="perfil-meta">✉️ @Model.Email</div>
            <div class="perfil-meta">🎓 @(string.IsNullOrEmpty(Model.Carrera) ? "Carrera no registrada" : Model.Carrera) · @Model.Rol</div>
        </div>
        <div class="perfil-settings">⚙️</div>
    </div>

    <!-- Estadísticas reales -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-icon icon-pink">✓</div>
            <div>
                <div class="stat-number">@Model.Completadas</div>
                <div class="stat-label">Tareas completadas</div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon icon-amber">🏆</div>
            <div>
                <div class="stat-number">@Model.Puntos</div>
                <div class="stat-label">Puntos totales</div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon icon-orange">📌</div>
            <div>
                <div class="stat-number">@Model.Pendientes</div>
                <div class="stat-label">Pendientes</div>
            </div>
        </div>

        <div class="stat-card">
            <div class="progress-ring" style="background: conic-gradient(#a3001d @(Model.Progreso)%, #f0d6db 0);">
                <span>@Model.Progreso%</span>
            </div>
            <div>
                <div class="stat-number">@Model.Progreso%</div>
                <div class="stat-label">Progreso</div>
            </div>
        </div>
    </div>

    <!-- Mis cursos -->
    <div class="dash-card" style="margin-bottom:24px;">
        <div class="dash-head"><h3>📖 Mis cursos</h3></div>

        @if (Model.Cursos.Any())
        {
            <div class="cursos-grid">
                @foreach (var curso in Model.Cursos)
                {
                    <div class="curso-chip">@curso</div>
                }
            </div>
        }
        else
        {
            <p class="item-sub">Aún no hay cursos registrados.</p>
        }
    </div>

    <!-- Insignias y logros -->
    <div class="dash-card">
        <div class="dash-head"><h3>🏅 Insignias y logros</h3></div>

        <div class="insignias-grid">
            @foreach (var ins in Model.Insignias)
            {
                <div class="insignia-card @(ins.Desbloqueada ? "" : "locked")">
                    <div class="insignia-emoji">@ins.Emoji</div>
                    <h5>@ins.Titulo</h5>
                    <p>@ins.Descripcion</p>
                </div>
            }
        </div>
    </div>

</div>