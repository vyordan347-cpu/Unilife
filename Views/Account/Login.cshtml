@model Unilife.Models.LoginViewModel

@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - UniLife</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>

<body class="login-page">

    <div class="login-container">

        <div class="login-logo">
            <img src="/img/logo-unilife.png.png" alt="UniLife" />
        </div>

        <h1 class="login-title">UniLife</h1>
        <p class="login-subtitle">Tu compañero universitario completo</p>

        <div class="login-card">
            <h2>Iniciar sesión</h2>

            <form asp-action="Login" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Correo electrónico</label>
                    <div class="input-wrapper">
                        <span class="input-icon">✉</span>
                        <input asp-for="Email" class="form-control login-input" placeholder="correo@usmp.pe" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Contraseña</label>
                    <div class="input-wrapper">
                        <span class="input-icon">🔒</span>
                        <input asp-for="Password" class="form-control login-input" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-login">
                    Iniciar sesión
                </button>

            </form>

            <div class="login-register">
                <a href="#">¿No tienes cuenta? Crear cuenta</a>
            </div>
        </div>

        <div class="login-footer">
            Al continuar, aceptas nuestros términos y condiciones
        </div>

        <div class="login-web">
            usmp.pe
        </div>

        <div class="social-icons">
            <span>f</span>
            <span>◎</span>
            <span>𝕏</span>
            <span>in</span>
            <span>▶</span>
        </div>
    </div>

    <div class="help-btn">?</div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

</body>
</html>