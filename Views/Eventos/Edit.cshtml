@model Unilife.Models.Evento

<h2>Editar Evento</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />

    <input asp-for="Titulo" class="form-control" />
    <input asp-for="Descripcion" class="form-control" />
    <input asp-for="Fecha" type="date" class="form-control" />
    <input asp-for="Hora" type="time" class="form-control" />
    <input asp-for="Lugar" class="form-control" />

    <select asp-for="TipoEvento" class="form-control">
        <option value="Charla">Charla</option>
        <option value="Taller">Taller</option>
        <option value="Hackathon">Hackathon</option>
        <option value="Conferencia">Conferencia</option>
        <option value="Deporte">Deporte</option>
        <option value="Arte">Arte</option>
        <option value="Música">Música</option>
    </select>

    <input asp-for="CarreraId" class="form-control" />

    <br />
    <button type="submit" class="btn btn-warning">Actualizar</button>
</form>