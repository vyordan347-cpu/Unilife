@model Unilife.Models.Evento

@{
    ViewData["Title"] = "Crear Evento";
}

<h2>Crear Evento</h2>

<form asp-action="Create">
    <div class="form-group">
        <label>Título</label>
        <input asp-for="Titulo" class="form-control" />
    </div>

    <div class="form-group">
        <label>Descripción</label>
        <input asp-for="Descripcion" class="form-control" />
    </div>

    <div class="form-group">
        <label>Fecha</label>
        <input asp-for="Fecha" type="date" class="form-control" />
    </div>

    <div class="form-group">
        <label>Hora</label>
        <input asp-for="Hora" type="time" class="form-control" />
    </div>

    <div class="form-group">
        <label>Lugar</label>
        <input asp-for="Lugar" class="form-control" />
    </div>

    <div class="form-group">
        <label>Tipo</label>
        <select asp-for="TipoEvento" class="form-control">
            <option value="General">General</option>
            <option value="Carrera">Por carrera</option>
        </select>
    </div>

    <div class="form-group">
        <label>CarreraId (opcional)</label>
        <input asp-for="CarreraId" class="form-control" />
    </div>

    <br />
    <button type="submit" class="btn btn-success">Guardar</button>
</form>