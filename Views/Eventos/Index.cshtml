@model IEnumerable<Unilife.Models.Evento>

@{
    ViewData["Title"] = "Eventos";
    int contador = 0;
    var recomendadosIds = ViewBag.RecomendadosIds as HashSet<int> ?? new HashSet<int>();
    bool soloReco = (bool?)ViewBag.SoloRecomendados ?? false;
}

<h1 class="page-title">Eventos universitarios</h1>
<p class="page-subtitle">Descubre y participa en eventos de tu universidad</p>

@if (soloReco)
{
    <p class="page-subtitle">★ Mostrando solo lo recomendado para ti — <a asp-action="Index">ver todos</a></p>
}

<div class="d-flex flex-wrap gap-2 mb-4">
    <a asp-action="Index" class="filter-btn active">Todos</a>
    <a asp-action="Index" asp-route-tipoEvento="Hackathon" class="filter-btn">⌘ Hackathons</a>
    <a asp-action="Index" asp-route-tipoEvento="Taller" class="filter-btn">☕ Talleres</a>
    <a asp-action="Index" asp-route-tipoEvento="Charla" class="filter-btn">♙ Charlas</a>
    <a asp-action="Index" asp-route-tipoEvento="Concierto" class="filter-btn">♫ Conciertos</a>
</div>

<form method="get" class="mb-4">
    <input type="text" name="buscar" value="@ViewBag.Buscar" class="form-control search-box" placeholder="Buscar eventos..." />
</form>

<div class="row g-4">
    @foreach (var item in Model)
    {
        string[] colores = { "gradient-purple", "gradient-red", "gradient-orange", "gradient-pink" };
        string color = colores[contador % colores.Length];
        contador++;

        <div class="col-md-6">
            <div class="event-card">
                <div class="event-header @color">
                    <span>◇ @item.TipoEvento</span>
                    <span>♡</span>
                </div>
                <div class="event-body">
                    @if (recomendadosIds.Contains(item.Id))
                    {
                        <div class="mb-2"><span class="badge-reco">★ Recomendado para ti</span></div>
                    }

                    <h5 class="event-title">@item.Titulo</h5>
                    <div class="info-line">📅 @item.Fecha.ToShortDateString()</div>
                    <div class="info-line">🕒 @item.Hora</div>
                    <div class="info-line">📍 @item.Lugar</div>
                    <div class="info-line">👥 Evento universitario</div>
                    <div class="mt-4">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-red">Ver detalle</a>
                    </div>
                    @if (User.IsInRole("Coordinador"))
                    {
                        <div class="d-flex gap-2 mt-3">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm w-50">Editar</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm w-50">Eliminar</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@if (User.IsInRole("Coordinador"))
{
    <div class="mt-4">
        <a asp-action="Create" class="btn btn-danger px-4">+ Crear evento</a>
    </div>
}