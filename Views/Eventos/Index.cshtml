@model IEnumerable<Unilife.Models.Evento>

@{
    ViewData["Title"] = "Eventos";
}

<h2>Eventos</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Crear nuevo evento</a>
</p>

<form method="get">
    <label>Filtrar por tipo:</label>
    <select name="tipoEvento">
        <option value="">Todos</option>
        <option value="General">General</option>
        <option value="Carrera">Por carrera</option>
    </select>
    <button type="submit" class="btn btn-secondary">Filtrar</button>
</form>

<table class="table table-bordered mt-3">
    <thead>
        <tr>
            <th>Título</th>
            <th>Fecha</th>
            <th>Hora</th>
            <th>Lugar</th>
            <th>Tipo</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.Titulo</td>
            <td>@item.Fecha.ToShortDateString()</td>
            <td>@item.Hora</td>
            <td>@item.Lugar</td>
            <td>@item.TipoEvento</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id">Ver</a> |
                <a asp-action="Edit" asp-route-id="@item.Id">Editar</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Eliminar</a>
            </td>
        </tr>
}
    </tbody>
</table>